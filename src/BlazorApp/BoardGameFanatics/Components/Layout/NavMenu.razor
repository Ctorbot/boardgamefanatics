<AuthorizeView>
    <Authorized>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="/players" Icon="@Icons.Material.Filled.People">Players</MudNavLink>
            <MudNavLink Href="@($"/players/{context.User.FindFirst(ClaimTypes.NameIdentifier)?.Value}/collection")"
                        Icon="@Icons.Material.Filled.LibraryBooks">My Collection</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/account/logout" Icon="@Icons.Material.Filled.Logout">Logout</MudNavLink>
        </MudNavMenu>
        <AuthorizeView Roles="Admin" Context="adminCtx">
            <MudNavMenu>
                <MudDivider Class="my-2" />
                <MudNavGroup Title="Admin" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="true">
                    <MudNavLink Href="/admin/players" Icon="@Icons.Material.Filled.HowToReg">Pending Players</MudNavLink>
                </MudNavGroup>
            </MudNavMenu>
        </AuthorizeView>
    </Authorized>
    <NotAuthorized>
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
            <MudNavLink Href="/players" Icon="@Icons.Material.Filled.People">Players</MudNavLink>
            <MudDivider Class="my-2" />
            <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
            <MudNavLink Href="/signup" Icon="@Icons.Material.Filled.PersonAdd">Sign Up</MudNavLink>
        </MudNavMenu>
    </NotAuthorized>
</AuthorizeView>
